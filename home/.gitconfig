[core]
  excludesfile = ~/.gitignore_global
  eol = native
  autocrlf = input
  pager = delta

[user]
  useConfigOnly = true

[init]
  defaultBranch = main

[includeIf "gitdir/i:~/proj/personal/"]
  path = ~/.gitconfig-personal

[includeIf "gitdir/i:~/proj/codeberg/"]
  path = ~/.gitconfig-codeberg

[includeIf "gitdir/i:~/proj/work/"]
  path = ~/.gitconfig-work

[interactive]
  diffFilter = delta --color-only

[delta]
  navigate = true  # use n and N to move between diff sections
  dark = true      # or light = true, or omit for auto-detection
  line-numbers = true

[merge]
  conflictStyle = zdiff3
